# AIRLAB Website - Production Environment Variables Template
# Copy this file to .env.production and fill in the values

# ============================================
# ADMIN AUTHENTICATION
# ============================================
# IMPORTANT: Change this to a strong password!
# Minimum 12 characters, mix of letters, numbers, and symbols
ADMIN_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# ============================================
# SECURITY
# ============================================
# Generate a secure JWT secret (minimum 32 characters)
# You can generate one using: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_32_CHARS

# ============================================
# SITE CONFIGURATION
# ============================================
# Production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://airlab.unilag.edu.ng

# Site name
NEXT_PUBLIC_SITE_NAME=AIRLAB UNILAG

# ============================================
# CONTACT INFORMATION
# ============================================
# Contact email for the website
NEXT_PUBLIC_CONTACT_EMAIL=airol@unilag.edu.ng

# ============================================
# OPTIONAL: ANALYTICS
# ============================================
# Google Analytics ID (if you want to track visitors)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# OPTIONAL: MONITORING
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# NOTES
# ============================================
# 1. Never commit .env.production to version control
# 2. Keep this file secure and backed up
# 3. Use strong, unique passwords
# 4. Rotate secrets regularly
# 5. Use environment-specific values for each deployment
