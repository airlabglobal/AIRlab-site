# Admin Authentication (REQUIRED in production)
ADMIN_PASSWORD=your_secure_password_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://airlab.unilag.edu.ng
NEXT_PUBLIC_SITE_NAME=AIRLAB UNILAG

# Contact Form (Resend Email Service)
# RESEND_API_KEY is required for sending emails via /api/contact
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL="AIRLAB Contact <onboarding@resend.dev>"
NEXT_PUBLIC_CONTACT_EMAIL=airol@unilag.edu.ng

# Security (REQUIRED in production - must be at least 32 characters)
JWT_SECRET=your_jwt_secret_here_min_32_characters

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
MONGODB_URI=MONGO_DB_CLUSTER_CONNECTION_STRING